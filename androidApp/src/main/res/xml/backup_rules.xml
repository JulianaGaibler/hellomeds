<?xml version="1.0" encoding="utf-8"?><!-- HelloMeds stores sensitive health data (medications, adherence history).
     All data must remain on-device only — no auto-backup.
     Note: This file is ignored for devices older than API 31.
     See https://developer.android.com/about/versions/12/backup-restore -->
<full-backup-content>
    <exclude
        domain="root"
        path="." />
    <exclude
        domain="database"
        path="." />
    <exclude
        domain="sharedpref"
        path="." />
    <exclude
        domain="file"
        path="." />
</full-backup-content>
