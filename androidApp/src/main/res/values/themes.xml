<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HelloMeds" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen theme (light) -->
    <style name="Theme.HelloMeds.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.HelloMeds</item>
    </style>

    <!-- Splash screen colors (light) — Material You dynamic surface -->
    <color name="splash_background">@android:color/system_neutral1_50</color>

</resources>
