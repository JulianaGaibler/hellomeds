#!/usr/bin/env bash
set -euo pipefail

# ── Spotless pre-commit check ────────────────────────────────────────────────
# Checks formatting of all Kotlin files in the working tree.
# To skip (e.g., WIP commits): git commit --no-verify
#
# NOTE: This checks the working tree, not the staged index. If you use
# `git add -p` (partial staging), fix formatting before staging, not after.

# Detect JAVA_HOME (same logic as ./hm)
if [ -z "${JAVA_HOME:-}" ]; then
    if [ -d "/Applications/Android Studio.app/Contents/jbr/Contents/Home" ]; then
        export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
    elif command -v /usr/libexec/java_home &>/dev/null; then
        export JAVA_HOME="$(/usr/libexec/java_home 2>/dev/null)" || true
    fi
fi

# Only run if there are staged .kt or .kts files
STAGED_KT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(kt|kts)$' || true)
if [ -z "$STAGED_KT" ]; then
    exit 0
fi

echo "Running spotlessCheck on Kotlin files..."

if ! ./gradlew spotlessCheck --quiet 2>&1; then
    echo ""
    echo "╭─────────────────────────────────────────────────╮"
    echo "│  Formatting issues found.                       │"
    echo "│  Run: ./gradlew spotlessApply                   │"
    echo "│  Or:  ./hm format                               │"
    echo "╰─────────────────────────────────────────────────╯"
    echo ""
    exit 1
fi
